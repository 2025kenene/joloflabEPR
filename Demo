function printFacture(id){google.script.run.withSuccessHandler(function(r){if(!r.success)return;var f=r.facture,c=r.client,v=r.vente,p=r.produit,e=r.entreprise,num=f.numero||('FAC-'+f.id),mt=fmt(f.montant);var ph='<!DOCTYPE html><html><head><meta charset="UTF-8"><title>'+num+'</title><style>body{font-family:Arial;margin:40px;color:#333}table{width:100%;border-collapse:collapse}th,td{padding:10px}th{background:#f5f5f5;font-size:12px;text-transform:uppercase;color:#666}td{border-bottom:1px solid #eee}.total{font-size:18px;font-weight:bold;color:'+e.couleur+'}</style></head><body>';ph+='<div style="display:flex;justify-content:space-between;border-bottom:3px solid '+e.couleur+';padding-bottom:20px;margin-bottom:20px"><div><h1 style="margin:0;color:'+e.couleur+'">'+e.nom+'</h1><p style="color:#666">'+e.adresse+'<br>'+e.telephone+' | '+e.email+(e.ninea?'<br>NINEA: '+e.ninea:'')+'</p></div><div style="text-align:right"><h2>FACTURE</h2><p>N°: '+num+'<br>Date: '+fmtDate(f.created_at)+'<br>Échéance: '+fmtDate(f.date_echeance)+'</p></div></div>';ph+='<div style="background:#f9f9f9;padding:16px;border-radius:8px;margin-bottom:20px"><small style="color:#666">FACTURÉ À</small><br><strong>'+c.nom+'</strong>'+(c.email?'<br>'+c.email:'')+(c.telephone?'<br>'+c.telephone:'')+'</div>';ph+='<table><thead><tr><th style="text-align:left">Produit</th><th style="text-align:center">Qté</th><th style="text-align:right">P.U.</th><th style="text-align:right">Total</th></tr></thead><tbody><tr><td>'+p.nom+'</td><td style="text-align:center">'+(v.quantite||1)+'</td><td style="text-align:right">'+fmt(p.prix)+' '+e.devise+'</td><td style="text-align:right;font-weight:bold">'+mt+' '+e.devise+'</td></tr></tbody></table>';ph+='<div style="text-align:right;margin-top:20px" class="total">TOTAL: '+mt+' '+e.devise+'</div>';if(e.conditions)ph+='<p style="font-size:12px;color:#888;margin-top:20px">'+e.conditions+'</p>';ph+='<script>window.onload=function(){window.print();}<\/script></body></html>';var w=window.open('','_blank');if(w){w.document.write(ph);w.document.close();}}).getFactureDetails(id);}
function emailFacture(id){var fac=(cachedData.factures||[]).find(function(x){return x.id==id;});var h='<div style="text-align:center;margin-bottom:16px"><i class="fas fa-paper-plane" style="font-size:2.5rem;color:var(--info)"></i><h4>Envoyer '+(fac&&fac.numero?fac.numero:'#'+id)+'</h4></div><div class="modal-form-group"><label>Email</label><input class="modal-input" id="mEmailTo" type="email" placeholder="client@email.com"></div><div class="modal-actions" style="justify-content:center"><button class="modal-cancel" onclick="closeModal()">Annuler</button><button class="primary-btn" onclick="sendEmail('+id+')" style="background:linear-gradient(135deg,var(--info),#5558E0)"><i class="fas fa-paper-plane"></i> Envoyer</button></div>';openModal('Email',h);}
function sendEmail(id){var em=document.getElementById('mEmailTo').value;if(!em){showToast('Email requis','error');return;}closeModal();showToast('Envoi...','info');google.script.run.withSuccessHandler(function(r){showToast(r.success?r.message:'Erreur: '+r.error,r.success?'success':'error');if(r.success)loadFactures();}).sendFactureByEmail(id,em);}

/* ═══ CLIENTS ═══ */
function loadClients(){google.script.run.withSuccessHandler(function(r){if(!r.success)return;cachedData.clients=r.data;var colors=['#D4973B','#C75C3A','#4A90D9','#2EBD6B','#9C64D2','#E8A838'],h='';r.data.forEach(function(c,i){h+='<div class="client-card"><div class="client-top"><div class="client-avatar" style="background:'+colors[i%colors.length]+'">'+((c.nom||'?').charAt(0).toUpperCase())+'</div><div><div class="client-name">'+c.nom+'</div><div class="client-email">'+(c.email||'—')+'</div></div></div><div style="font-size:.82rem;color:var(--text-muted)"><i class="fas fa-phone" style="margin-right:4px"></i>'+(c.telephone||'—')+'</div><div class="client-card-actions"><button class="btn-edit" style="flex:1;padding:8px;border-radius:var(--radius-sm);font-size:.8rem" onclick="editClient('+c.id+')"><i class="fas fa-pen"></i> Modifier</button><button class="btn-edit" style="flex:1;padding:8px;border-radius:var(--radius-sm);font-size:.8rem;background:rgba(99,102,241,0.1);color:var(--info)" onclick="viewClientHistory('+c.id+',\''+c.nom.replace(/'/g,"\'")+'\')"><i class="fas fa-file-invoice"></i> Factures</button><button class="btn-delete" style="flex:0;padding:8px 10px;border-radius:var(--radius-sm);font-size:.8rem" onclick="confirmDelete(\'client\','+c.id+')"><i class="fas fa-trash"></i></button></div></div>';});if(!h)h='<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted)">Aucun client</div>';document.getElementById('clientsGrid').innerHTML=h;}).getClients();}
function openClientModal(ed){var h='<div class="modal-form-group"><label>Nom</label><input class="modal-input" id="mCN" value="'+(ed?ed.nom:'')+'"></div><div class="modal-form-group"><label>Email</label><input class="modal-input" id="mCE" value="'+(ed?ed.email:'')+'"></div><div class="modal-form-group"><label>Tél</label><input class="modal-input" id="mCT" value="'+(ed?ed.telephone:'')+'"></div><div class="modal-form-group"><label>Adresse</label><input class="modal-input" id="mCA" value="'+(ed?ed.adresse:'')+'"></div><div class="modal-actions"><button class="modal-cancel" onclick="closeModal()">Annuler</button><button class="primary-btn" onclick="saveClient('+(ed?ed.id:'null')+')"><i class="fas fa-check"></i> OK</button></div>';openModal(ed?'Modifier Client':'Nouveau Client',h);}
function saveClient(eid){var d={nom:document.getElementById('mCN').value,email:document.getElementById('mCE').value,telephone:document.getElementById('mCT').value,adresse:document.getElementById('mCA').value};if(!d.nom){showToast('Nom requis','error');return;}closeModal();if(eid)google.script.run.withSuccessHandler(function(r){showToast(r.success?'OK':'Erreur','success');loadClients();}).updateClient(eid,d);else google.script.run.withSuccessHandler(function(r){showToast(r.success?'Ajouté':'Erreur','success');loadClients();}).addClient(d);}
function editClient(id){var c=(cachedData.clients||[]).find(function(x){return x.id==id;});if(c)openClientModal(c);}
function viewClientHistory(cid,cnom){showToast('Chargement...','info');google.script.run.withSuccessHandler(function(r){if(!r.success)return;var h='<strong>'+r.data.length+'</strong> facture(s) pour <strong>'+cnom+'</strong>';if(r.data.length>0){h+='<table style="width:100%;border-collapse:collapse;margin-top:12px"><thead><tr style="background:var(--bg-surface)"><th style="padding:10px;font-size:.75rem;color:var(--text-muted)">N°</th><th style="padding:10px;text-align:right;font-size:.75rem;color:var(--text-muted)">Montant</th><th style="padding:10px;font-size:.75rem;color:var(--text-muted)">Statut</th><th style="padding:10px;font-size:.75rem;color:var(--text-muted)">Date</th></tr></thead><tbody>';r.data.forEach(function(f){var sc=f.statut==='payé'||f.statut==='paye'?'paid':f.statut==='envoyée'?'sent':'pending';h+='<tr><td style="padding:10px;border-bottom:1px solid var(--border)">'+(f.numero||'#'+f.id)+'</td><td style="padding:10px;text-align:right;font-weight:600;border-bottom:1px solid var(--border)">'+fmt(f.montant)+'</td><td style="padding:10px;border-bottom:1px solid var(--border)"><span class="status-badge '+sc+'"><span class="status-dot"></span>'+(f.statut==='payé'||f.statut==='paye'?'Payé':f.statut==='envoyée'?'Envoyée':'En attente')+'</span></td><td style="padding:10px;border-bottom:1px solid var(--border);color:var(--text-muted)">'+fmtDate(f.created_at)+'</td></tr>';});h+='</tbody></table>';}openModal('Historique — '+cnom,h);}).getFacturesClient(cid);}

/* ═══ USERS ═══ */
function loadUsers(){google.script.run.withSuccessHandler(function(r){if(!r.success)return;cachedData.users=r.data;var h='';r.data.forEach(function(u){var rb=u.role==='admin'?'<span style="background:var(--primary-glow);color:var(--primary);padding:2px 10px;border-radius:12px;font-size:.75rem;font-weight:600">Admin</span>':'<span style="background:rgba(74,144,217,0.1);color:#4A90D9;padding:2px 10px;border-radius:12px;font-size:.75rem;font-weight:600">'+u.role+'</span>';h+='<tr><td><strong>#'+u.id+'</strong></td><td>'+u.nom+'</td><td style="color:var(--text-muted)">'+u.email+'</td><td>'+rb+'</td><td><div class="action-btns"><button class="action-btn" onclick="editUser('+u.id+')"><i class="fas fa-pen"></i></button><button class="action-btn danger" onclick="confirmDelete(\'user\','+u.id+')"><i class="fas fa-trash"></i></button></div></td></tr>';});document.getElementById('usersTableBody').innerHTML=h;}).getUsers();}
function openUserModal(ed){var h='<div class="modal-form-group"><label>Nom</label><input class="modal-input" id="mUN" value="'+(ed?ed.nom:'')+'"></div><div class="modal-form-group"><label>Email</label><input class="modal-input" id="mUE" value="'+(ed?ed.email:'')+'"></div><div class="modal-form-group"><label>Rôle</label><select class="modal-input" id="mUR"><option value="admin"'+(ed&&ed.role==='admin'?' selected':'')+'>Admin</option><option value="vendeur"'+(ed&&ed.role==='vendeur'?' selected':'')+'>Vendeur</option><option value="comptable"'+(ed&&ed.role==='comptable'?' selected':'')+'>Comptable</option><option value="stockeur"'+(ed&&ed.role==='stockeur'?' selected':'')+'>Stockeur</option></select></div><div class="modal-form-group"><label>Mot de passe'+(ed?' (vide=inchangé)':'')+'</label><input class="modal-input" id="mUP" type="password"></div><div class="modal-actions"><button class="modal-cancel" onclick="closeModal()">Annuler</button><button class="primary-btn" onclick="saveUser('+(ed?ed.id:'null')+')"><i class="fas fa-check"></i> OK</button></div>';openModal(ed?'Modifier':'Nouvel Utilisateur',h);}
function saveUser(eid){var d={nom:document.getElementById('mUN').value,email:document.getElementById('mUE').value,role:document.getElementById('mUR').value};var p=document.getElementById('mUP').value;if(p)d.password=p;if(!d.nom||!d.email){showToast('Requis','error');return;}closeModal();if(eid)google.script.run.withSuccessHandler(function(r){showToast(r.success?'OK':'Erreur','success');loadUsers();}).updateUser(eid,d);else{if(!p){showToast('Mot de passe requis','error');return;}d.password=p;google.script.run.withSuccessHandler(function(r){showToast(r.success?'Créé':'Erreur','success');loadUsers();}).addUser(d);}}
function editUser(id){var u=(cachedData.users||[]).find(function(x){return x.id==id;});if(u)openUserModal(u);}

/* ═══ CONFIG ═══ */
function loadConfig(){google.script.run.withSuccessHandler(function(c){document.getElementById('cfgNom').value=c.nom||'';document.getElementById('cfgAdresse').value=c.adresse||'';document.getElementById('cfgTelephone').value=c.telephone||'';document.getElementById('cfgEmail').value=c.email||'';document.getElementById('cfgNinea').value=c.ninea||'';document.getElementById('cfgRc').value=c.rc||'';document.getElementById('cfgDevise').value=c.devise||'FCFA';document.getElementById('cfgCouleur').value=c.couleur||'#E8611A';document.getElementById('cfgConditions').value=c.conditions||'';}).getEntrepriseConfig();}
function saveConfig(){var c={nom:document.getElementById('cfgNom').value,adresse:document.getElementById('cfgAdresse').value,telephone:document.getElementById('cfgTelephone').value,email:document.getElementById('cfgEmail').value,ninea:document.getElementById('cfgNinea').value,rc:document.getElementById('cfgRc').value,devise:document.getElementById('cfgDevise').value,couleur:document.getElementById('cfgCouleur').value,conditions:document.getElementById('cfgConditions').value};showToast('Sauvegarde...','info');google.script.run.withSuccessHandler(function(r){showToast(r.success?'Sauvegardé !':'Erreur',r.success?'success':'error');}).saveEntrepriseConfig(c);}

/* ═══ DELETE ═══ */
function confirmDelete(type,id){var lb={produit:'ce produit',client:'ce client',vente:'cette vente',facture:'cette facture',user:'cet utilisateur',depense:'cette dépense'};openModal('Confirmer','<div style="text-align:center;padding:10px 0"><i class="fas fa-exclamation-triangle" style="font-size:3rem;color:var(--danger);margin-bottom:16px"></i><p>Supprimer '+(lb[type]||'cet élément')+' ?</p><div class="modal-actions" style="justify-content:center;margin-top:20px"><button class="modal-cancel" onclick="closeModal()">Annuler</button><button class="primary-btn" style="background:linear-gradient(135deg,var(--danger),#C73A3A)" onclick="execDelete(\''+type+'\','+id+')"><i class="fas fa-trash"></i> Supprimer</button></div></div>');}
function execDelete(type,id){closeModal();var fn={produit:'deleteProduit',client:'deleteClient',vente:'deleteVente',facture:'deleteFacture',user:'deleteUser'};var rl={produit:loadProduits,client:loadClients,vente:loadVentes,facture:loadFactures,user:loadUsers};if(type==='depense'){google.script.run.withSuccessHandler(function(r){showToast(r.success?'Supprimé':'Erreur',r.success?'success':'error');loadCompta();}).deleteRow('depenses_raws',id);return;}google.script.run.withSuccessHandler(function(r){showToast(r.success?'Supprimé':'Erreur',r.success?'success':'error');if(rl[type])rl[type]();})[fn[type]](id);}

/* ═══ MODAL & TOAST ═══ */
function openModal(t,h){document.getElementById('modalTitle').textContent=t;document.getElementById('modalBody').innerHTML=h;var o=document.getElementById('modalOverlay');o.style.display='flex';setTimeout(function(){o.classList.add('show');},10);}
function closeModal(){var o=document.getElementById('modalOverlay');o.classList.remove('show');setTimeout(function(){o.style.display='none';},300);}
document.addEventListener('click',function(e){if(e.target.id==='modalOverlay')closeModal();});
function showToast(m,t){t=t||'info';var ic={success:'fa-check-circle',error:'fa-times-circle',info:'fa-info-circle'};var c=document.getElementById('toastContainer'),el=document.createElement('div');el.className='toast '+t;el.innerHTML='<i class="fas '+(ic[t]||ic.info)+'"></i><span>'+m+'</span>';c.appendChild(el);setTimeout(function(){el.style.animation='toastOut 0.3s ease forwards';setTimeout(function(){el.remove();},300);},3500);}
</script>
